# =============================================================================
# Copy this file to ".env" and fill in secrets. Never commit ".env".
# Command: cp .env.example .env
# =============================================================================

# --- Airflow (host user id for volume permissions; Linux/Mac) -------------
AIRFLOW_UID=50000

# First Airflow UI user (airflow-init). Override defaults if needed.
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# --- Google Gemini (silver DAG; airflow-init seeds Airflow Variables) -------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- AWS / Localstack (used by Airflow workers/scheduler for S3/SQS hooks) --
# Dummy values are fine for Localstack. Override for real AWS in production.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566

# --- LocalStack web UI (LocalUI; http://localhost:8088 by default) ------------
# LOCALSTACK_UI_PORT=8088

# --- FastAPI service (optional; values also used when calling Airflow API) ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
AIRFLOW_URL=http://airflow-webserver:8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin

# --- Optional: Postgres (only if you parameterize docker-compose for prod) ---
# POSTGRES_USER=airflow
# POSTGRES_PASSWORD=airflow
# POSTGRES_DB=airflow
